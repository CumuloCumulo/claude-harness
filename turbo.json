{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": [".next/**", "!.next/cache/**", "out/**"]
    },
    "generate": {
      "outputs": ["packages/web/generated/**", "packages/web/public/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
